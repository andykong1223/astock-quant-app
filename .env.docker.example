# Docker / 生产环境变量（复制为 .env.docker 后填写）
# cp .env.docker.example .env.docker

# ---- 对外端口 ----
HTTP_PORT=80

# ---- 前端构建期注入（VITE_* 会打进静态资源）----
VITE_API_BASE_URL=/api/v1
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
VITE_SUPABASE_ANON_KEY=sb_publishable_xxx
VITE_DEMO_MODE=false

# ---- 后端运行时 ----
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
SUPABASE_SECRET_KEY=sb_secret_xxx
SUPABASE_JWKS_URL=https://your-project.supabase.co/auth/v1/.well-known/jwks.json
SUPABASE_ANON_KEY=sb_publishable_xxx
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx

DATA_PROVIDER=eastmoney
DATA_API_BASE_URL=https://push2delay.eastmoney.com

# 启用 Redis 时：docker compose --profile redis up -d
# 并把 REDIS_ENABLED 改为 true
REDIS_ENABLED=false
REDIS_HOST=redis
REDIS_PORT=6379

NODE_ENV=production
PORT=3000
DEMO_MODE=false

CRON_UPDATE_QUOTES=30 15 * * 1-5
CRON_SYNC_LIST=10 9 * * 1-5
CRON_SYNC_REALTIME=*/5 9-14 * * 1-5
